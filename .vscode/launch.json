{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "CvMobileApplication",
      "request": "launch",
      "mainClass": "com.cvmobile.CvMobileApplication",
      "projectName": "cv-mobile-backend"
    },
    {
      "name": "Mobile - Émulateur Android",
      "request": "launch",
      "type": "dart",
      "program": "mobile/lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=http://10.0.2.2:8082/api"
      ]
    },
    {
      "name": "Mobile - Simulateur iOS",
      "request": "launch",
      "type": "dart",
      "program": "mobile/lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=http://localhost:8082/api"
      ]
    },
    {
      "name": "Mobile - Appareil physique (LAN)",
      "request": "launch",
      "type": "dart",
      "program": "mobile/lib/main.dart",
      "args": [
        "--dart-define=API_BASE_URL=http://192.168.1.100:8082/api"
      ],
      "comment": "Remplacer 192.168.1.100 par l'IP de votre machine"
    }
  ]
}
