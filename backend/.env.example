# ============================================================
# CV Mobile Backend — Variables d'environnement
#
# 1. Copiez ce fichier en .env : cp .env.example .env
# 2. Remplissez les valeurs reelles
# 3. NE JAMAIS committer le fichier .env (deja dans .gitignore)
#
# Pour la prod, injectez ces variables via votre orchestrateur
# (Docker secrets, Kubernetes secrets, AWS SSM, etc.)
# ============================================================

# --- Profil Spring actif (dev | prod | test) ---
SPRING_PROFILES_ACTIVE=dev

# --- Base de donnees PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/cvmobile
DB_USERNAME=postgres
DB_PASSWORD=change_me

# --- JWT ---
# Generer avec : openssl rand -base64 64
# Minimum 256 bits (44+ caracteres en base64)
JWT_SECRET=your_very_long_secret_key_at_least_256_bits_here
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- CORS ---
# Origines autorisees, separees par des virgules
# Dev typique : http://localhost:3000,http://localhost:3001,http://localhost:8082,http://10.0.2.2:8082
# Prod : https://app.votredomaine.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8082,http://10.0.2.2:8082

# --- Serveur ---
SERVER_PORT=8082

# --- Debug ---
# false en prod OBLIGATOIRE
SHOW_SQL=false

# --- DeepSeek AI API ---
# Obtenir une cle sur https://platform.deepseek.com/
# Optionnel en dev (mode degrade), OBLIGATOIRE en prod
DEEPSEEK_API_KEY=
AI_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Upload ---
UPLOAD_DIR=./uploads
