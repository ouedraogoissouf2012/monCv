# ============================================================
# CV Mobile Backend — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS committer le fichier .env
# ============================================================

# --- Base de données PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/cvmobile
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# --- JWT ---
# Clé secrète : minimum 256 bits (32 caractères)
# Générer avec : openssl rand -base64 64
JWT_SECRET=your_very_long_secret_key_at_least_256_bits_here
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- CORS ---
# Origines autorisées séparées par des virgules
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Serveur ---
SERVER_PORT=8082

# --- Debug (false en production) ---
SHOW_SQL=false
