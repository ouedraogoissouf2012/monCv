# ============================================================
# Variables d'environnement requises pour le backend CV Mobile
# Copiez ce fichier en .env et remplissez les valeurs
# IMPORTANT : Ne jamais committer le fichier .env
# ============================================================

# Base de données PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/cvmobile
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# JWT - Générer un secret fort (min 256 bits / 32 caractères)
# Commande pour générer : openssl rand -base64 64
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_minimum_32_chars
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Serveur
SERVER_PORT=8082

# CORS - origines autorisées (séparées par virgule, sans espaces)
# Dev local : inclure l'émulateur Android (10.0.2.2) et localhost
# Prod : mettre uniquement les domaines de production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://10.0.2.2:8082

# Logs SQL (true uniquement en développement)
SHOW_SQL=false
