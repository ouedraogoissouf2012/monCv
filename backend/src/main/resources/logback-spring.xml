<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Include defaults Spring Boot (pattern de base, conversions, etc.) -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ============================================================ -->
    <!-- Console appender classique (dev, test)                       -->
    <!-- ============================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ============================================================ -->
    <!-- JSON appender (prod) - structure pour les collecteurs de logs -->
    <!-- ============================================================ -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdc>true</includeMdc>
            <includeContext>false</includeContext>
            <customFields>{"application":"cv-mobile-backend"}</customFields>
        </encoder>
    </appender>

    <!-- ============================================================ -->
    <!-- Profils Spring : activation selective                        -->
    <!-- ============================================================ -->

    <!-- Dev / Test : console lisible -->
    <springProfile name="dev,test,default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.cvmobile" level="DEBUG"/>
    </springProfile>

    <!-- Prod : JSON structure pour les agregateurs (ELK, Datadog, etc.) -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
        <logger name="com.cvmobile" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
    </springProfile>

</configuration>
